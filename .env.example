# Upstash Box API Key
# console.upstash.com → Box → API Keys
UPSTASH_BOX_API_KEY=your_box_api_key

# Telegram
# BotFather'dan alınan token
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz
# Mesaj gönderilecek chat ID
TELEGRAM_CHAT_ID=123456789

# Upstash Redis
# console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Deploy sonrası hemen test için "true" yap
RUN_ON_START=false
